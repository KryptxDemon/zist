
PROJECT_NAME=Zist API
VERSION=1.0.0
API_V1_STR=/api/v1

# Local SQLite example:
# DATABASE_URL=sqlite:///./zist.db
# PostgreSQL/Neon example:
# DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require&channel_binding=require
DATABASE_URL=sqlite:///./zist.db

SECRET_KEY=super-secret-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3

OPENLIBRARY_BASE_URL=https://openlibrary.org

WIKIPEDIA_API_BASE=https://en.wikipedia.org/api/rest_v1

DICTIONARY_API_BASE=https://api.dictionaryapi.dev/api/v2/entries/en