
PROJECT_NAME=Zist API
VERSION=1.0.0
API_V1_STR=/api/v1

# Database Configuration
# For local development: sqlite:///./zist.db
# For production (Neon PostgreSQL): postgresql://user:password@host/database?sslmode=require
DATABASE_URL=sqlite:///./zist.db

# Security (CHANGE THESE IN PRODUCTION!)
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (comma-separated, no spaces)
# Development: http://localhost:5173,http://127.0.0.1:5173
# Production: https://zist-media.netlify.app,https://your-backend.onrender.com
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# External API Keys
TMDB_API_KEY=your-tmdb-api-key
TMDB_BASE_URL=https://api.themoviedb.org/3
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# External Service URLs (usually don't need changing)
OPENLIBRARY_BASE_URL=https://openlibrary.org
WIKIPEDIA_API_BASE=https://en.wikipedia.org/api/rest_v1
DICTIONARY_API_BASE=https://api.dictionaryapi.dev/api/v2/entries/en